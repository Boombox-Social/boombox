# Example Environment Variables
# Copy this file to .env.local for local development
# Copy this file to .env.production and update with production values

# Database Configuration
POSTGRES_URL="postgresql://username:password@host:5432/database?schema=public"
DATABASE_URL="postgresql://username:password@host:5432/database?schema=public"

# JWT Secrets (use strong, random values in production)
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# API Configuration
NEXT_PUBLIC_API_KEY="http://localhost:3000/api"
