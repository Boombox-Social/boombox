generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  name           String
  role           UserRole  @default(SMM)
  avatar         String?
  isActive       Boolean   @default(true)
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  password       String
  clients        Client[]
  createdClients Client[]  @relation("ClientCreator")

  @@map("users")
}

model Client {
  id                   Int      @id @default(autoincrement())
  logo                 String?
  name                 String
  address              String?
  industry             String?
  slogan               String?
  links                String[]
  coreProducts         String[]
  idealCustomers       String?
  brandEmotion         String?
  uniqueProposition    String?
  whyChooseUs          String?
  mainGoal             String?
  shortTermGoal        String?
  longTermGoal         String?
  competitors          String[]
  indirectCompetitors  String[]
  brandAssets          String[]
  fontUsed             String[]
  smmDriveLink         String?
  contractDeliverables String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  assignedUserId  Int? // Keep existing field
  assignedUser    User?        @relation(fields: [assignedUserId], references: [id])
  assignedUserIds Int[]        @default([]) // NEW: Array of all assigned SMM user IDs
  createdById     Int // User who created this client
  createdBy       User         @relation("ClientCreator", fields: [createdById], references: [id])
  ClientLinks     ClientLinks? @relation(fields: [clientLinksId], references: [id])
  clientLinksId   Int?

  // NEW: Relation to Influencer Projects
  influencerProjects InfluencerProject[]

  @@map("clients")
}

//Links for the cards on client info dashboard
model ClientLinks {
  id                  Int      @id @default(autoincrement())
  clientId            Int
  strategyAiLink      String?
  businessSummaryLink String?
  basecampLink        String?
  contentCreationLink String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  Client              Client[]

  @@map("client_links")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SMM
}

model ArchivedClient {
  id                   Int      @id @default(autoincrement())
  originalClientId     Int // Reference to the original client
  logo                 String?
  name                 String
  address              String?
  industry             String?
  slogan               String?
  links                String[]
  coreProducts         String[]
  idealCustomers       String?
  brandEmotion         String?
  uniqueProposition    String?
  whyChooseUs          String?
  mainGoal             String?
  shortTermGoal        String?
  longTermGoal         String?
  competitors          String[]
  indirectCompetitors  String[]
  brandAssets          String[]
  fontUsed             String[]
  smmDriveLink         String?
  contractDeliverables String?
  archivedAt           DateTime @default(now())
  assignedUserIds      Int[]
  createdById          Int
  clientLinksId        Int?
  // Optionally, add a relation to User if you want to track who archived
  // archivedById         Int?
  // archivedBy           User? @relation(fields: [archivedById], references: [id])

  @@map("archived_clients")
}

// ==========================================
// NEW MODELS FOR INFLUENCER MANAGEMENT
// ==========================================

model InfluencerMasterList {
  id                 Int      @id @default(autoincrement())
  name               String
  tag                String?
  niche              String?
  username           String   @unique
  
  // Stored as String because your sheets have data like "34.3K", "350K+", or "1M+"
  // If you plan to sort by followers later, consider cleaning data on import and using `Int`
  tiktokFollowers    String?  
  facebookFollowers  String?
  instagramFollowers String?
  
  tier               Tier?    // Uses the enum below (A, B, C)
  contentStyle       String?
  avgViews           String?  // String to allow ranges/approximations like "10k-20k"
  contact            String?
  notes              String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relation to projects they belong to
  projects           ProjectInfluencer[]

  @@map("influencer_master_list")
}

model InfluencerProject {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Ayo Ayo Campaign - Jan-Apr 2026"
  description String?
  
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id])

  // Defines the dynamic "Schema" of columns for this specific project spreadsheet.
  // Example: [{"key": "vouchers", "label": "Vouchers Given", "type": "number"}, {"key": "visit_date", "label": "Visit Date", "type": "date"}]
  dynamicColumnsDef Json?    @default("[]") 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  influencers ProjectInfluencer[]

  @@map("influencer_projects")
}

// Pivot/Junction Table linking Influencers to specific Projects
model ProjectInfluencer {
  id               Int      @id @default(autoincrement())
  
  projectId        Int
  project          InfluencerProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  influencerId     Int
  influencer       InfluencerMasterList @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  // DYNAMIC COLUMNS DATA GOES HERE
  // This stores the actual cell values for this influencer in this project
  // Example: { "vouchers": 2, "visit_date": "2026-03-12", "intro_sent": "Y", "post_link": "https://tiktok.com/..." }
  dynamicData      Json?    @default("{}")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([projectId, influencerId]) // An influencer can only be added to the same project once
  @@map("project_influencers")
}

enum Tier {
  A
  B
  C
  D
}
